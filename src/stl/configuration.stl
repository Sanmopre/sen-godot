package configuration;

enum Model : u32
{
  defaultModel,
  f18,
  a400,
  chaff,
  flare,
  c17,
  aim9
}

sequence<string> StringList;

struct ModelMapping
{
  disTypes : StringList,
  model    : Model
}

sequence<ModelMapping> ModelMappingList;

struct Viewport
{
  view   : string,
  layer  : u8,
  left   : f32,
  right  : f32,
  top    : f32,
  bottom : f32
}

sequence<Viewport> Viewports;

class EngineConfiguration
{
  var inputQueries  : StringList       [static];
  var modelMappings : ModelMappingList [static];
  var viewports     : Viewports        [confirmed];
}